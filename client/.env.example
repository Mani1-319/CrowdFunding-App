# Copy to .env for local dev. Vite only exposes vars prefixed with VITE_.
# Netlify: set the same variables in Site settings → Environment variables (build time).

# Render API URL (must include /api unless you rely on auto-append — see client/src/utils/env.js)
# VITE_API_URL=https://your-service.onrender.com/api

# Optional: override asset/socket origin. If unset, derived from VITE_API_URL.
# VITE_PUBLIC_API_ORIGIN=https://your-service.onrender.com

# Optional: Socket.io URL (origin only). If unset, same as public API origin above.
# VITE_SOCKET_URL=https://your-service.onrender.com

# Razorpay (publishable key only — never put the secret in the client)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
