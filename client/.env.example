# Copy to .env for local dev. Vite only exposes vars prefixed with VITE_.

# API base URL (omit in production when app and API share the same origin)
# VITE_API_URL=http://localhost:5000/api

# When the Vite dev server (5173) loads images from the API (5000), set:
# VITE_PUBLIC_API_ORIGIN=http://localhost:5000

# Razorpay (publishable key only — never put the secret in the client)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# If the frontend is on a different domain than Socket.io, set the API origin:
# VITE_SOCKET_URL=https://your-api.example.com
