PORT=5000
NODE_ENV=development
# Production (Render): required so Netlify can call the API and Socket.io (https, no trailing slash).
# CLIENT_ORIGIN=https://your-app.netlify.app
# Optional: comma-separated list for multiple frontends
# CLIENT_ORIGINS=https://app.netlify.app,http://localhost:5173

# Neon: paste the connection string; add ?sslmode=require if not already present.
# Optional if the host string is not auto-detected: DATABASE_SSL=true

DATABASE_URL=postgres://postgres:password@localhost:5432/crowdfunding_db
JWT_SECRET=your_super_secret_key_here

# Gmail: use a Google "App password" (2FA required). Not your normal Gmail password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Mobile OTP (Twilio SMS). Sign up at https://www.twilio.com — use trial number for dev.
# Without these, mobile OTP is not sent unless SMS_LOG_OTP=true (logs OTP in server console only).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# SMS_LOG_OTP=false

RAZORPAY_KEY_ID=rzp_test_dummykey
RAZORPAY_KEY_SECRET=rzp_test_dummy_secret
